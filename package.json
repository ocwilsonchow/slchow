{
  "name": "slchow",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "lint": "turbo run lint",
    "sso": "aws sso login --sso-session=sinlongchow",
    "dev": "bunx sst dev --stage local"
  },
  "devDependencies": {
    "@types/aws-lambda": "8.10.162",
    "prettier": "^3.7.4",
    "turbo": "^2.9.18",
    "typescript": "5.9.2"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.14",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "dependencies": {
    "sst": "4.15.2"
  }
}
